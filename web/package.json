{
  "name": "sithub-web",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:unit": "vitest run",
    "test:unit:coverage": "vitest run --coverage",
    "test:e2e": "cypress run",
    "test:e2e:open": "cypress open",
    "test:e2e:auth:unauth": "cypress run --spec cypress/e2e/auth.cy.ts",
    "test:e2e:auth:test": "CYPRESS_testAuthEnabled=true cypress run --spec cypress/e2e/auth.cy.ts",
    "lint": "eslint . --max-warnings 0",
    "type-check": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@mdi/js": "^7.4.47",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0",
    "vuetify": "^3.12.9"
  },
  "overrides": {
    "flatted": "^3.4.2",
    "yauzl": "^3.2.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^3.2.7",
    "@vue/eslint-config-typescript": "^14.9.0",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "cypress": "^15.12.0",
    "eslint": "^9.39.5",
    "eslint-plugin-vue": "^10.9.2",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.9.3",
    "vite": "^8.1.3",
    "vitest": "^3.2.6",
    "vue-tsc": "^3.3.6"
  }
}
