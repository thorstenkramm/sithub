{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sithub_areas.schema.json",
  "title": "SitHub Areas Configuration",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "areas": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "items"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "floor_plan": {
            "type": "string",
            "minLength": 1
          },
          "icon": {
            "type": "string",
            "pattern": "^mdi-[a-z0-9-]+$",
            "description": "MDI icon name from https://pictogrammers.com (e.g. mdi-office-building)"
          },
          "max_bookings_per_person": {
            "type": "integer",
            "minimum": 0,
            "description": "Maximum active bookings per person for this area. 0 or omitted means unlimited. Overrides the global limit from sithub.toml."
          },
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "id",
                "name",
                "items"
              ],
              "properties": {
                "id": {
                  "type": "string",
                  "minLength": 1
                },
                "name": {
                  "type": "string",
                  "minLength": 1
                },
                "description": {
                  "type": "string"
                },
                "floor_plan": {
                  "type": "string",
                  "minLength": 1
                },
                "icon": {
                  "type": "string",
                  "pattern": "^mdi-[a-z0-9-]+$",
                  "description": "MDI icon name from https://pictogrammers.com (e.g. mdi-door)"
                },
                "max_bookings_per_person": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Maximum active bookings per person for this item group. 0 or omitted means unlimited. Overrides area-level limit."
                },
                "items": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "id",
                      "name"
                    ],
                    "properties": {
                      "id": {
                        "type": "string",
                        "minLength": 1
                      },
                      "name": {
                        "type": "string",
                        "minLength": 1
                      },
                      "equipment": {
                        "type": "array",
                        "items": {
                          "type": "string",
                          "minLength": 1
                        }
                      },
                      "warning": {
                        "type": "string"
                      },
                      "icon": {
                        "type": "string",
                        "pattern": "^mdi-[a-z0-9-]+$",
                        "description": "MDI icon name from https://pictogrammers.com (e.g. mdi-desk)"
                      },
                      "max_bookings_per_person": {
                        "type": "integer",
                        "minimum": 0,
                        "description": "Maximum active bookings per person for this item. 0 or omitted means unlimited. Overrides item-group-level limit."
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "required": [
    "areas"
  ]
}
